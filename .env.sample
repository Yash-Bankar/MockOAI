# =========================
# Database
# =========================
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# =========================
# Better Auth
# =========================
BETTER_AUTH_SECRET="your-32-byte-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# =========================
# Google OAuth
# =========================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =========================
# Gemini AI
# =========================
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"  # Default — GA, free-tier eligible. Override if needed.

PISTON_URL="http://localhost:2000/api/v2"

# =========================
# Optional (Production)
# =========================
NODE_ENV="development"

# ai      = always call Gemini (original behavior)
# static  = always use the static JSON bank, never call Gemini
# hybrid  = call Gemini once; on failure, fall back to static and stay on
#           static for 6h (circuit breaker) to avoid burning daily quota
QUESTION_SOURCE_MODE="hybrid"

# Two INDEPENDENT switches — MCQ and coding don't have to run the same mode.
# Both fall back to QUESTION_SOURCE_MODE if their specific var isn't set.
# Uncomment and adjust below to split the behavior:
MCQ_SOURCE_MODE="static"
CODING_SOURCE_MODE="ai"