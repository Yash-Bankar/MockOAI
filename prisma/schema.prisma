generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth core models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  profile       UserProfile?
  examAttempts  ExamAttempt[]
  followedBy    Follow[] @relation("following")
  following     Follow[] @relation("follower")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String   @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Domain models ────────────────────────────────────────────────────────────

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college        String?
  branch         String?
  graduationYear Int?
  bio            String?
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  totalAttempts  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum SectionFormat {
  MCQ
  CODING
}

model ExamPattern {
  id          String           @id @default(cuid())
  name        String
  description String?
  maxScore    Int
  isActive    Boolean          @default(true)
  sections    SectionConfig[]
  attempts    ExamAttempt[]
  createdAt   DateTime         @default(now())
}

model SectionConfig {
  id              String        @id @default(cuid())
  patternId       String
  pattern         ExamPattern   @relation(fields: [patternId], references: [id], onDelete: Cascade)
  name            String
  order           Int
  maxScore        Int
  questionCount   Int
  format          SectionFormat
  questionTypeMix Json
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model ExamAttempt {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  patternId       String
  pattern         ExamPattern      @relation(fields: [patternId], references: [id])
  status          AttemptStatus    @default(IN_PROGRESS)
  startedAt       DateTime         @default(now())
  completedAt     DateTime?
  totalScore      Float?
  maxScore        Int
  durationSeconds Int
  aiSummary       String?
  sections        AttemptSection[]
  createdAt       DateTime         @default(now())
}

model AttemptSection {
  id               String        @id @default(cuid())
  attemptId        String
  attempt          ExamAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  sectionConfigId  String
  name             String
  order            Int
  maxScore         Int
  scoreObtained    Float?
  timeSpentSeconds Int           @default(0)
  status           AttemptStatus @default(IN_PROGRESS)
  questions        Question[]
}

enum QuestionFormat {
  MCQ
  CODING
}

model Question {
  id               String          @id @default(cuid())
  attemptSectionId String
  attemptSection   AttemptSection  @relation(fields: [attemptSectionId], references: [id], onDelete: Cascade)
  type             QuestionFormat
  subType          String
  difficulty       String?
  order            Int
  maxScore         Float
  promptText       String          @db.Text
  options          Json?
  correctOptionId  String?
  explanation      String?         @db.Text
  codingMeta       Json?
  submission       Submission?
  createdAt        DateTime        @default(now())
}

model Submission {
  id               String   @id @default(cuid())
  questionId       String   @unique
  question         Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionId String?
  code             String?  @db.Text
  language         String?
  isCorrect        Boolean?
  scoreAwarded     Float    @default(0)
  testCaseResults  Json?
  aiFeedback       String?  @db.Text
  timeSpentSeconds Int      @default(0)
  attemptCount     Int      @default(0)
  updatedAt        DateTime @updatedAt
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}
